# Required
BOT_TOKEN=your-telegram-bot-token
OWNER_ID=your-telegram-id

# Claude — Option A (recommended): Anthropic API key
ANTHROPIC_API_KEY=your-api-key
# Option B: leave empty, use claude CLI (mount ~/.claude as volume)

# Model (SDK mode)
CLAUDE_MODEL=sonnet

# Timeouts
CLAUDE_TIMEOUT=90

# Memory
MAX_HISTORY=20
MAX_FACTS=50

# Groups
GROUP_RANDOM_CHANCE=0.07

# Whisper model: tiny/base/small/medium/large
WHISPER_MODEL=tiny

# TTS — Voice responses (Fish Audio)
TTS_ENABLED=false
FISH_AUDIO_API_KEY=your-fish-audio-api-key
FISH_AUDIO_VOICE_ID=d2e75a3e3fd6419893057c02a375a113
